# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: bedrock | claude | gemini | openai
LLM_PROVIDER=bedrock

# ── AWS Bedrock (preferred for production — uses IAM, no API keys) ─────────────
AWS_REGION=ca-central-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# No API key needed — boto3 uses the EC2 instance IAM role automatically

# ── Anthropic Direct (for local dev) ──────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Google Gemini ──────────────────────────────────────────────────────────────
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash

# ── OpenAI ─────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── LlamaParse (primary PDF parser — highest accuracy) ─────────────────────────
# Get key at: https://cloud.llamaindex.ai
LLAMA_CLOUD_API_KEY=llx-...

# ── Parser settings ────────────────────────────────────────────────────────────
# LLAMAPARSE_PREMIUM_MODE=true      # enables AI-powered table + OCR
# LLAMAPARSE_RESULT_TYPE=markdown   # markdown | text
# OCR_DPI=300
