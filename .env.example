# =============================================
# FAST Improved — Environment Configuration
# =============================================

# App
SECRET_KEY=change-me-in-production

# LLM Provider: gemini | openai | claude (default: gemini)
LLM_PROVIDER=gemini

# Google Gemini (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# OpenAI GPT-4 (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# Anthropic Claude (required if LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-6

# Default admin password (used on first run — change immediately)
ADMIN_PASSWORD=admin
