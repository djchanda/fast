# =============================================
# FAST Improved — Environment Configuration
# =============================================

# App
SECRET_KEY=change-me-in-production

# LLM Provider: bedrock | gemini | openai | claude  (default: gemini)
# For AWS deployments, set LLM_PROVIDER=bedrock — no API key required.
# Auth comes from the EC2 instance role / IAM credentials automatically.
LLM_PROVIDER=gemini

# ── AWS Bedrock (recommended for AWS deployments) ─────────────────────────
# No API key needed — uses the EC2 instance profile / IAM role.
# Requires the instance role to have bedrock:InvokeModel permission.
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ── Google Gemini (required if LLM_PROVIDER=gemini) ───────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ── OpenAI GPT-4 (required if LLM_PROVIDER=openai) ───────────────────────
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# ── Anthropic Claude direct API (required if LLM_PROVIDER=claude) ─────────
# Only needed for direct Anthropic API access. For AWS, use bedrock instead.
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-6

# Default admin password (used on first run — change immediately)
ADMIN_PASSWORD=admin
